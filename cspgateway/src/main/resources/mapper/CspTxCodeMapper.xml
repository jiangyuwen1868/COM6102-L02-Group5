<?xml version="1.0" encoding="UTF-8" ?>      
<!DOCTYPE mapper    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jyw.csp.mapper.CspTxCodeMapper">

	<resultMap type="com.jyw.csp.entity.CspTxCodeEntity" id="CspTxCodeResultMap">
   </resultMap>
    <select id="count" databaseId="mysql">
		SELECT count(*) FROM csp_txcode
    </select>
    <select id="count" databaseId="oracle">
		SELECT count(*) FROM csp_txcode
    </select>
    
    <select id="select" resultMap="CspTxCodeResultMap" databaseId="mysql">
		SELECT * FROM csp_txcode WHERE txcode=#{txcode}
    </select>
    <select id="select" resultMap="CspTxCodeResultMap" databaseId="oracle">
		SELECT * FROM csp_txcode WHERE txcode=#{txcode,jdbcType=VARCHAR}
    </select>
    
    <select id="selectAll" resultMap="CspTxCodeResultMap" databaseId="mysql">
		SELECT * FROM csp_txcode
    </select>   
    <select id="selectAll" resultMap="CspTxCodeResultMap" databaseId="oracle">
		SELECT * FROM csp_txcode
    </select>
    
</mapper>